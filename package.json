{
  "name": "taipei-kitchen-forms",
  "version": "2.1.0",
  "description": "Taipei Kitchen Bento operations system - production, delivery, food safety, and analytics",
  "scripts": {
    "deploy": "cp .clasp.staging.json .clasp.json && clasp push",
    "deploy:staging": "cp .clasp.staging.json .clasp.json && clasp push",
    "deploy:production": "cp .clasp.production.json .clasp.json && clasp push",
    "watch": "clasp push --watch",
    "open": "clasp open",
    "open:staging": "cp .clasp.staging.json .clasp.json && clasp open",
    "open:production": "cp .clasp.production.json .clasp.json && clasp open",
    "logs": "clasp logs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/romanogelsomino-blip/taipei-kitchen-forms.git"
  },
  "author": "Leander Toney <leandertoney@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  }
}
