{
  "name": "taipei-kitchen-forms",
  "version": "2.1.0",
  "description": "Taipei Kitchen Bento operations system - production, delivery, food safety, and analytics",
  "scripts": {
    "deploy": "bash scripts/deploy-staging.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "init:staging": "node scripts/admin-action.js staging init",
    "init:production": "node scripts/admin-action.js production init",
    "test:violation:staging": "node scripts/admin-action.js staging test",
    "test:violation:production": "node scripts/admin-action.js production test",
    "test:log:staging": "node scripts/admin-action.js staging getExecutionLog",
    "test:log:staging:all": "node scripts/admin-action.js staging getExecutionLog 500",
    "test:log:production": "node scripts/admin-action.js production getExecutionLog",
    "test:log:production:all": "node scripts/admin-action.js production getExecutionLog 500",
    "test:triggers:staging": "node scripts/admin-action.js staging listTriggers",
    "test:triggers:production": "node scripts/admin-action.js production listTriggers",
    "test:malformed:staging": "node scripts/test-malformed-post.js staging",
    "test:malformed:production": "node scripts/test-malformed-post.js production",
    "test:photo:staging": "node scripts/test-photo-upload.js staging",
    "test:photo:production": "node scripts/test-photo-upload.js production",
    "email:summary:staging": "node scripts/admin-action.js staging sendDailySummary",
    "email:summary:production": "node scripts/admin-action.js production sendDailySummary",
    "trigger:create:staging": "node scripts/admin-action.js staging createTrigger",
    "trigger:create:production": "node scripts/admin-action.js production createTrigger",
    "trigger:delete:staging": "node scripts/admin-action.js staging deleteTrigger sendDailySummary",
    "trigger:delete:production": "node scripts/admin-action.js production deleteTrigger sendDailySummary",
    "ping:staging": "node scripts/admin-action.js staging ping",
    "ping:production": "node scripts/admin-action.js production ping",
    "config:reset:staging": "node scripts/admin-action.js staging resetConfig",
    "config:reset:production": "node scripts/admin-action.js production resetConfig",
    "watch": "clasp push --watch",
    "open": "clasp open",
    "open:staging": "cp .clasp.staging.json .clasp.json && clasp open",
    "open:production": "cp .clasp.production.json .clasp.json && clasp open",
    "logs": "clasp logs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/romanogelsomino-blip/taipei-kitchen-forms.git"
  },
  "author": "Leander Toney <leandertoney@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  }
}
